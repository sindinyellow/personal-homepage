---
import { profile } from '@/data/profile';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div>
    <strong>{profile.name}</strong>
    <span>持续记录项目、学习和解决问题的过程。</span>
  </div>
  <div class="footer-links">
    <a href={`mailto:${profile.email}`}>邮箱</a>
    <a href={profile.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={profile.gitee} target="_blank" rel="noopener noreferrer">Gitee</a>
    {profile.resumeUrl && profile.resumeUrl !== '#' && (
      <a href={profile.resumeUrl} target="_blank" rel="noopener noreferrer">下载简历</a>
    )}
  </div>
  <small>&copy; {year} {profile.name}. Built with Astro.</small>
</footer>
