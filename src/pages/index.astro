---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { profile, projects, skills } from '@/data/profile';
import { calcReadingTime } from '@/utils/readingTime';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const resumeReady = profile.resumeUrl && profile.resumeUrl !== '#';
const primaryStack = skills.slice(0, 6);
const contactLinks = [
  { label: 'GitHub', href: profile.github },
  { label: 'Gitee', href: profile.gitee },
];
---

<BaseLayout title={`${profile.name} - Java / Vue 全栈开发工程师`} description={profile.summary}>
  <!-- Hero -->
  <section class="hero section-wrap">
    <div class="hero-copy">
      <p class="eyebrow animate-in">求职作品集 / 技术博客</p>
      <h1 class="animate-in delay-1">{profile.name}</h1>
      <p class="hero-role animate-in delay-2">{profile.role}</p>
      <p class="animate-in delay-2">{profile.summary}</p>
      <div class="hero-stack animate-in delay-3" aria-label="核心技术栈">
        {primaryStack.map((skill) => <span>{skill}</span>)}
      </div>
      <div class="hero-actions animate-in delay-3">
        <a class="button primary" href="/projects/">查看项目</a>
        <a class="button secondary" href="/blog/">阅读博客</a>
        {
          resumeReady ? (
            <a class="button secondary" href={profile.resumeUrl} target="_blank" rel="noopener noreferrer">查看简历</a>
          ) : (
            <span class="button muted" aria-disabled="true">简历待更新</span>
          )
        }
      </div>
    </div>
    <aside class="profile-panel animate-in delay-3" aria-label="个人信息摘要">
      <img src="/profile-card.svg" alt="个人主页封面视觉" width="520" height="360" />
      <div class="contact-grid">
        <span>状态</span><strong>{profile.availability}</strong>
        <span>城市</span><strong>{profile.location}</strong>
        <span>主页</span>
        <span class="inline-links">
          {contactLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </span>
      </div>
    </aside>
  </section>

  <!-- 求职速览 -->
  <section class="section-wrap content-section">
    <div class="section-heading animate-in">
      <div>
        <p class="eyebrow">招聘方速览</p>
        <h2>我能承担的工作。</h2>
      </div>
      <span class="section-note">{profile.availability}</span>
    </div>
    <div class="focus-grid">
      {profile.focusAreas.map((item, i) => (
        <article class={`focus-card animate-in delay-${Math.min(i + 1, 3)}`}>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- 技能栈 -->
  <section class="section-wrap split-section">
    <div class="animate-in">
      <p class="eyebrow">技能栈</p>
      <h2>专注 Web 全栈开发和业务系统落地。</h2>
      <ul class="clean-list highlight-list">
        {profile.careerHighlights.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="skill-grid animate-in delay-1">
      {skills.map((skill) => <span>{skill}</span>)}
    </div>
  </section>

  <!-- 精选项目 -->
  <section class="section-wrap content-section">
    <div class="section-heading animate-in">
      <div>
        <p class="eyebrow">精选项目</p>
        <h2>把项目经历讲清楚。</h2>
      </div>
      <a href="/projects/">全部项目</a>
    </div>
    <div class="project-list">
      {projects.slice(0, 2).map((project, i) => (
        <div class={`animate-in delay-${i + 1}`}>
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="section-wrap content-section">
    <div class="section-heading animate-in">
      <div>
        <p class="eyebrow">最新文章</p>
        <h2>记录学习、复盘和问题解决。</h2>
      </div>
      <a href="/blog/">全部文章</a>
    </div>
    <div class="post-grid">
      {posts.map((post, i) => (
        <div class={`animate-in delay-${i + 1}`}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.slug}/`}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            readingTime={calcReadingTime(post.body)}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
