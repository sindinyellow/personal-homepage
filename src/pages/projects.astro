---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { profile, projects } from '@/data/profile';
---

<BaseLayout title={`项目经历 - ${profile.name}`} description="个人项目经历、技术栈和职责成果展示。">
  <section class="page-hero section-wrap compact">
    <p class="eyebrow">Projects</p>
    <h1>项目经历</h1>
    <p>这里集中展示可以写进简历、面试时展开讲的项目。把占位内容替换成真实成果后，就能作为简历链接的主要落点。</p>
  </section>

  <section class="section-wrap content-section">
    <div class="project-list">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>
</BaseLayout>
