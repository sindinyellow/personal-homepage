---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { profile, projects } from '@/data/profile';
---

<BaseLayout title={`项目经历 - ${profile.name}`} description="个人项目经历、技术栈和职责成果展示。">
  <section class="page-hero section-wrap compact">
    <p class="eyebrow animate-in">Projects</p>
    <h1 class="animate-in delay-1">项目经历</h1>
    <p class="animate-in delay-2">用项目说明我能完成的业务开发工作：从需求拆解、接口设计、权限控制到前端页面落地。</p>
    <div class="page-highlights animate-in delay-3">
      {profile.careerHighlights.map((item) => <span>{item}</span>)}
    </div>
  </section>

  <section class="section-wrap content-section">
    <div class="section-heading animate-in">
      <div>
        <p class="eyebrow">Project Evidence</p>
        <h2>项目不只列技术栈，也说明职责和落地价值。</h2>
      </div>
    </div>
    <div class="project-list">
      {projects.map((project, i) => (
        <div class={`animate-in delay-${Math.min(i + 1, 4)}`}>
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
